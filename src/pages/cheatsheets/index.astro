---
import Layout from '../../layouts/Layout.astro';
import { CHEATSHEETS } from '../../data/cheatsheets';
import { DOMAINS } from '../../data/types';

const base = import.meta.env.BASE_URL;
---

<Layout title="Cheat Sheets" description="Quick-reference cheat sheets for the AWS services that matter most on the Developer Associate exam.">
  <div class="pop-in mb-8 text-center">
    <h1 class="text-3xl font-black text-white sm:text-4xl">Cheat Sheets 📋</h1>
    <p class="mt-2 text-slate-300">Skim before the exam or whenever a concept needs a refresher.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {
      CHEATSHEETS.map((sheet) => {
        const domainInfo = DOMAINS.find((d) => d.id === sheet.domain)!;
        return (
          <a
            href={`${base}cheatsheets/${sheet.slug}/`}
            class="card p-6 transition hover:-translate-y-1 hover:border-[var(--color-aws-orange)]/40"
          >
            <div class="flex items-center justify-between">
              <span class="text-3xl">{sheet.icon}</span>
              <span
                class="rounded-full px-2.5 py-0.5 text-xs font-bold"
                style={`background-color:${domainInfo.color}22; color:${domainInfo.color}`}
              >
                {domainInfo.shortLabel}
              </span>
            </div>
            <h2 class="mt-3 font-bold text-white">{sheet.title}</h2>
            <p class="mt-1 text-sm text-slate-400">{sheet.summary}</p>
          </a>
        );
      })
    }
  </div>
</Layout>
