---
import Layout from '../layouts/Layout.astro';
import Flashcards from '../components/Flashcards.tsx';
import { FLASHCARDS } from '../data/flashcards';
import { DOMAINS } from '../data/types';
---

<Layout title="Flashcards" description="Flip through AWS Developer Associate flashcards for fast recall.">
  <div class="pop-in mb-8 text-center">
    <h1 class="text-3xl font-black text-white sm:text-4xl">Flashcards 🃏</h1>
    <p class="mt-2 text-slate-300">Flip, self-rate, and shuffle until it sticks.</p>
  </div>
  <Flashcards client:load cards={FLASHCARDS} domains={DOMAINS} />
</Layout>
