---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A fun, fast way to prep for the AWS Certified Developer – Associate exam.' } = Astro.props;

const nav = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/quiz/', label: 'Quiz', icon: '🎮' },
  { href: '/flashcards/', label: 'Flashcards', icon: '🃏' },
  { href: '/cheatsheets/', label: 'Cheat Sheets', icon: '📋' },
];

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title} · AWS Dev Associate Prep</title>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-20 border-b border-white/10 bg-[var(--color-aws-navy)]/85 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 sm:px-6">
        <a href={base} class="flex items-center gap-2 text-lg font-black text-white">
          <span class="text-2xl">☁️</span>
          <span>
            AWS<span class="text-[var(--color-aws-orange)]">DVA</span> Prep
          </span>
        </a>
        <nav class="flex gap-1 sm:gap-2">
          {
            nav.map((item) => {
              const href = item.href === '/' ? base : `${base}${item.href.slice(1)}`;
              const isActive =
                item.href === '/' ? currentPath === base || currentPath === `${base}/` : currentPath.startsWith(href);
              return (
                <a
                  href={href}
                  class:list={[
                    'rounded-lg px-2.5 py-1.5 text-sm font-semibold transition sm:px-3.5',
                    isActive
                      ? 'bg-[var(--color-aws-orange)] text-[var(--color-aws-navy)]'
                      : 'text-slate-300 hover:bg-white/10 hover:text-white',
                  ]}
                >
                  <span class="sm:hidden">{item.icon}</span>
                  <span class="hidden sm:inline">
                    {item.icon} {item.label}
                  </span>
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-12">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-4 pb-10 pt-4 text-center text-xs text-slate-500 sm:px-6">
      Built for AWS Certified Developer – Associate (DVA-C02) prep. Not affiliated with Amazon Web Services.
    </footer>
  </body>
</html>
